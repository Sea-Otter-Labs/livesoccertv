# API-Football 配置
API_FOOTBALL_KEY=your_api_key_here

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=football_broadcasts
DB_USER=root
DB_PASSWORD=your_password

# Lark 告警配置（可选）
LARK_WEBHOOK_URL=https://open.larksuite.com/open-apis/bot/v2/hook/your_webhook_token
LARK_SECRET=your_secret_key_here

# 告警配置
ALERT_ENABLED=true
ALERT_SEVERITY_THRESHOLD=medium

# 爬虫配置
CRAWL_CONCURRENCY=3
CRAWL_DELAY=2.0

# 对齐配置
ALIGN_TIME_TOLERANCE_HOURS=4.0
ALIGN_MIN_CONFIDENCE=0.8

# 911proxy 代理配置
PROXY_ENABLED=false
PROXY_HOST=proxy.911proxy.com
PROXY_PORT=8080
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# 911proxy API 配置（用于账户管理，可选）
PROXY_API_KEY=your_911proxy_app_key
